{
  "name": "sistema-registro-universitario",
  "version": "1.0.0",
  "description": "Sistema de Registro y Reinscripción Universitaria con patrones Proxy y Chain of Responsibility",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --coverageReporters=lcov --coverageReporters=text",
    "test:ci": "jest --coverage --coverageReporters=lcov --coverageReporters=text --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "server.js"
    ],
    "coverageDirectory": "coverage",
    "testTimeout": 10000
  },
  "keywords": [
    "registro",
    "universidad",
    "proxy",
    "chain-of-responsibility",
    "patron-diseno"
  ],
  "author": "Emmanuel",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.4"
  }
}
